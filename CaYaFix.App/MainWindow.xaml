<Window x:Class="CaYaFix.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:app="clr-namespace:CaYaFix.App"
        xmlns:p="clr-namespace:CaYaFix.App.Properties"
        mc:Ignorable="d"
        Title="CaYaFix"
        x:Name="RootWindow"
        Width="1360" Height="860"
        MinWidth="860" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            ResizeBorderThickness="6"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
        <KeyBinding Key="D1" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="0" />
        <KeyBinding Key="D2" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="1" />
        <KeyBinding Key="D3" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="2" />
        <KeyBinding Key="D4" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="3" />
        <KeyBinding Key="D5" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="4" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar (CaptionHeight=48: drag via chrome; IsHitTestVisibleInChrome for custom chrome hit-testing) -->
        <Border Grid.Row="0"
                Background="#091522"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                PreviewMouseLeftButtonDown="OnTitleBarMouseDown"
                MouseLeftButtonDown="OnTitleBarMouseDown">
            <Grid Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding ActualWidth, ElementName=RootWindow, Converter={StaticResource ResponsiveGridLength}, ConverterParameter=1120:220:76}" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0" IsHitTestVisible="False">
                    <app:SvgIcon Icon="logo.svg" Width="25" Height="25" IsHitTestVisible="False" />
                    <TextBlock Text="{x:Static p:Strings.AppName}" FontWeight="Bold" FontSize="15" Margin="9,0,0,0" VerticalAlignment="Center" Visibility="{Binding ActualWidth, ElementName=RootWindow, Converter={StaticResource WidthThresholdVisibility}, ConverterParameter=1120}" />
                    <Border Background="#16342F" CornerRadius="6" Padding="7,3" Margin="10,0,0,0" Visibility="{Binding ActualWidth, ElementName=RootWindow, Converter={StaticResource WidthThresholdVisibility}, ConverterParameter=1120}">
                        <TextBlock Text="{x:Static p:Strings.App_ReleaseChannel}" Foreground="{StaticResource PrimaryBrush}" FontSize="9" FontWeight="Bold" />
                    </Border>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding ActiveOperation}" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False" />
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Width="46" Height="47" Background="Transparent" BorderThickness="0" Click="OnMinimizeClick" shell:WindowChrome.IsHitTestVisibleInChrome="True" AutomationProperties.Name="{x:Static p:Strings.Action_Minimize}" ToolTip="{x:Static p:Strings.Action_Minimize}"><app:SvgIcon Icon="window-minimize.svg" Width="15" Height="15" IsHitTestVisible="False" /></Button>
                    <Button Width="46" Height="47" Background="Transparent" BorderThickness="0" Click="OnMaximizeClick" shell:WindowChrome.IsHitTestVisibleInChrome="True" AutomationProperties.Name="{x:Static p:Strings.Action_Maximize}" ToolTip="{x:Static p:Strings.Action_Maximize}"><app:SvgIcon Icon="window-maximize.svg" Width="15" Height="15" IsHitTestVisible="False" /></Button>
                    <Button Width="48" Height="47" Background="Transparent" BorderThickness="0" Click="OnCloseClick" shell:WindowChrome.IsHitTestVisibleInChrome="True" AutomationProperties.Name="{x:Static p:Strings.Action_Close}" ToolTip="{x:Static p:Strings.Action_Close}"><app:SvgIcon Icon="window-close.svg" Width="16" Height="16" IsHitTestVisible="False" /></Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding ActualWidth, ElementName=RootWindow, Converter={StaticResource ResponsiveGridLength}, ConverterParameter=1120:220:76}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid Margin="12,18,12,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="0" AutomationProperties.Name="{x:Static p:Strings.Nav_Home}" ToolTip="{x:Static p:Strings.Nav_Home}">
                            <StackPanel Orientation="Horizontal"><app:SvgIcon Icon="home.svg" Width="19" Height="19" Margin="0,0,10,0" IsHitTestVisible="False" /><TextBlock Text="{x:Static p:Strings.Nav_Home}" Visibility="{Binding ActualWidth, ElementName=RootWindow, Converter={StaticResource WidthThresholdVisibility}, ConverterParameter=1120}" /></StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="1" Margin="0,3,0,0" AutomationProperties.Name="{x:Static p:Strings.Nav_Findings}" ToolTip="{x:Static p:Strings.Nav_Findings}">
                            <StackPanel Orientation="Horizontal"><app:SvgIcon Icon="findings.svg" Width="19" Height="19" Margin="0,0,10,0" IsHitTestVisible="False" /><TextBlock Text="{x:Static p:Strings.Nav_Findings}" Visibility="{Binding ActualWidth, ElementName=RootWindow, Converter={StaticResource WidthThresholdVisibility}, ConverterParameter=1120}" /></StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="2" Margin="0,3,0,0" AutomationProperties.Name="{x:Static p:Strings.Nav_LiveTests}" ToolTip="{x:Static p:Strings.Nav_LiveTests}">
                            <StackPanel Orientation="Horizontal"><app:SvgIcon Icon="activity.svg" Width="19" Height="19" Margin="0,0,10,0" IsHitTestVisible="False" /><TextBlock Text="{x:Static p:Strings.Nav_LiveTests}" Visibility="{Binding ActualWidth, ElementName=RootWindow, Converter={StaticResource WidthThresholdVisibility}, ConverterParameter=1120}" /></StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="3" Margin="0,3,0,0" AutomationProperties.Name="{x:Static p:Strings.Nav_Recovery}" ToolTip="{x:Static p:Strings.Nav_Recovery}">
                            <StackPanel Orientation="Horizontal"><app:SvgIcon Icon="history.svg" Width="19" Height="19" Margin="0,0,10,0" IsHitTestVisible="False" /><TextBlock Text="{x:Static p:Strings.Nav_Recovery}" Visibility="{Binding ActualWidth, ElementName=RootWindow, Converter={StaticResource WidthThresholdVisibility}, ConverterParameter=1120}" /></StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="4" Margin="0,3,0,0" AutomationProperties.Name="{x:Static p:Strings.Nav_Settings}" ToolTip="{x:Static p:Strings.Nav_Settings}">
                            <StackPanel Orientation="Horizontal"><app:SvgIcon Icon="settings.svg" Width="19" Height="19" Margin="0,0,10,0" IsHitTestVisible="False" /><TextBlock Text="{x:Static p:Strings.Nav_Settings}" Visibility="{Binding ActualWidth, ElementName=RootWindow, Converter={StaticResource WidthThresholdVisibility}, ConverterParameter=1120}" /></StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <Border Background="#0E241F" BorderBrush="#225849" BorderThickness="1" CornerRadius="12" Padding="12" Visibility="{Binding ActualWidth, ElementName=RootWindow, Converter={StaticResource WidthThresholdVisibility}, ConverterParameter=1120}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0" />
                                    <TextBlock Text="{x:Static p:Strings.AdminMode}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" FontSize="12" />
                                </StackPanel>
                                <TextBlock Text="{Binding VersionLabel}" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="16,5,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#321C24"
                        BorderBrush="{StaticResource DangerBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Margin="18,14,18,0"
                        Padding="14"
                        Visibility="{Binding RecoveryRequired, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="38" Height="38" Background="#4A2430" CornerRadius="10" Margin="0,0,12,0">
                            <app:SvgIcon Icon="recovery.svg" Width="21" Height="21" IsHitTestVisible="False" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="{Binding RecoveryBannerTitle}" Foreground="#FFD6DE" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding RecoveryBannerText}" Foreground="#DDB9C2" FontSize="10.5" TextWrapping="Wrap" Margin="0,3,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="3"
                                Content="{x:Static p:Strings.Nav_Recovery}"
                                Padding="13,8"
                                VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <TabControl Grid.Row="1" Style="{StaticResource HiddenTabControl}" SelectedIndex="{Binding CurrentPage}">
                    <!-- Dashboard -->
                    <TabItem>
                        <ScrollViewer>
                            <Grid MaxWidth="1160" Margin="32,28,32,38" HorizontalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" CornerRadius="22" BorderBrush="#25524B" BorderThickness="1" Padding="34">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#12372F" Offset="0" />
                                            <GradientStop Color="#10263B" Offset="0.55" />
                                            <GradientStop Color="#0D1A2A" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="{Binding ActualWidth, ElementName=RootWindow, Converter={StaticResource ResponsiveGridLength}, ConverterParameter=1180:330:0}" /></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" MaxWidth="650" HorizontalAlignment="Left">
                                            <TextBlock Text="{x:Static p:Strings.Hero_Eyebrow}" Foreground="{StaticResource PrimaryBrush}" FontSize="11" FontWeight="Bold" />
                                            <TextBlock Text="{x:Static p:Strings.Hero_Title}" FontFamily="Segoe UI Variable Display, Segoe UI" FontWeight="Bold" FontSize="37" TextWrapping="Wrap" Margin="0,12,10,0" LineHeight="43" />
                                            <TextBlock Text="{x:Static p:Strings.Hero_Description}" Foreground="#B8C9DB" FontSize="14" TextWrapping="Wrap" LineHeight="22" Margin="0,15,30,0" />
                                            <StackPanel Orientation="Horizontal" Margin="0,25,0,0">
                                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding AutomaticScanCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" Padding="26,13">
                                                    <StackPanel Orientation="Horizontal"><app:SvgIcon Icon="search.svg" Width="18" Height="18" Margin="0,0,9,0" IsHitTestVisible="False" /><TextBlock Text="{x:Static p:Strings.Action_AutomaticScan}" Foreground="#07110F" /></StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Margin="10,0,0,0" Content="{x:Static p:Strings.Action_Cancel}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <Grid Grid.Column="1" Margin="30,0,0,0">
                                            <Ellipse Width="215" Height="215" Fill="#152E43" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Ellipse Width="158" Height="158" Fill="#173F3A" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Border Width="106" Height="122" CornerRadius="28,28,38,38" Background="#51DEC1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Grid>
                                                    <app:SvgIcon Icon="logo.svg" Width="106" Height="106" IsHitTestVisible="False" />
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1" Margin="0,30,0,15">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{x:Static p:Strings.Dashboard_Modules}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="24" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Static p:Strings.Dashboard_ModulesHint}" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#112C29" CornerRadius="10" Padding="12,7" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ModuleCountLabel}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" FontSize="11" />
                                    </Border>
                                </Grid>

                                <ItemsControl Grid.Row="2" ItemsSource="{Binding Modules}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="268" Margin="0,0,14,14" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="16">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                                <Setter Property="Background" Value="#122A3F" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Button Command="{Binding SelectCommand}" Style="{StaticResource BaseButton}" Padding="0" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                                                    <Grid Margin="18">
                                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                        <Grid Grid.Row="0">
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                            <Border Width="38" Height="38" CornerRadius="11" Background="#173B39"><app:SvgIcon Icon="{Binding IconPath}" Width="22" Height="22" IsHitTestVisible="False" /></Border>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" Margin="12,0,0,0" VerticalAlignment="Center" />
                                                            <app:SvgIcon Grid.Column="2" Icon="chevron-right.svg" Width="16" Height="16" IsHitTestVisible="False" />
                                                        </Grid>
                                                        <TextBlock Grid.Row="1" Text="{Binding Description}" Foreground="{StaticResource MutedBrush}" FontSize="11.5" TextWrapping="Wrap" LineHeight="17" Margin="0,11,0,0" />
                                                    </Grid>
                                                </Button>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Findings -->
                    <TabItem>
                        <Grid Margin="32,27,32,22">
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,18">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{x:Static p:Strings.Findings_Title}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="28" FontWeight="Bold" />
                                    <TextBlock Text="{x:Static p:Strings.Findings_Description}" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource SecondaryButton}" Command="{Binding OpenReportCommand}" Content="{x:Static p:Strings.Action_OpenReport}" Visibility="{Binding HasReport, Converter={StaticResource BoolToVisibility}}" Margin="0,0,8,0" />
                                    <Button Style="{StaticResource SecondaryButton}" Command="{Binding CreateSupportPackageCommand}" Content="{x:Static p:Strings.Action_CreateSupportPackage}" />
                                </StackPanel>
                            </Grid>

                            <ScrollViewer Grid.Row="1">
                                <Grid>
                                    <!-- No findings: pick a symptom and apply related repairs with risk warning -->
                                    <StackPanel Visibility="{Binding Findings.Count, Converter={StaticResource ZeroCountToVisibility}}" Margin="0,12,0,24">
                                        <Border Background="#102035" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="22" Margin="0,0,0,18">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <Border Width="40" Height="40" CornerRadius="11" Background="#173A37" Margin="0,0,12,0">
                                                        <app:SvgIcon Icon="check.svg" Width="22" Height="22" IsHitTestVisible="False" />
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Static p:Strings.Findings_None}" FontSize="18" FontWeight="SemiBold" />
                                                        <TextBlock Text="{x:Static p:Strings.GuidedRepair_Intro}" Foreground="{StaticResource MutedBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border Background="#271E18" BorderBrush="#6B4B29" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,4,0,0">
                                                    <TextBlock Text="{x:Static p:Strings.GuidedRepair_IntroRisk}" Foreground="#E8D2B4" FontSize="12" TextWrapping="Wrap" LineHeight="18" />
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="{x:Static p:Strings.GuidedRepair_PickTitle}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                                        <ItemsControl ItemsSource="{Binding GuidedSymptoms}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding SelectCommand}" Style="{StaticResource BaseButton}" Padding="0" Margin="0,0,12,12" Background="Transparent" BorderThickness="0">
                                                        <Border Width="300" MinHeight="108" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Width="40" Height="40" CornerRadius="11" Background="#173B39" Margin="0,0,12,0" VerticalAlignment="Top">
                                                                    <app:SvgIcon Icon="{Binding ModuleIcon}" Width="22" Height="22" IsHitTestVisible="False" />
                                                                </Border>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{Binding ModuleName}" Foreground="{StaticResource MutedBrush}" FontSize="10.5" />
                                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13.5" TextWrapping="Wrap" Margin="0,3,0,0" />
                                                                    <TextBlock Text="{Binding FixCountLabel}" Foreground="{StaticResource PrimaryBrush}" FontSize="11" Margin="0,8,0,0" />
                                                                    <TextBlock Text="{Binding FixTitlesPreview}" Foreground="#8FA3BA" FontSize="10.5" TextWrapping="Wrap" Margin="0,4,0,0" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Findings}" Visibility="{Binding Findings.Count, Converter={StaticResource CountToVisibility}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="18">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" IsEnabled="{Binding IsActionable}" VerticalAlignment="Top" Margin="0,5,14,0" />
                                                        <StackPanel Grid.Column="1">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Background="#17283B" CornerRadius="7" Padding="9,4" Margin="0,0,8,0">
                                                                    <TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding Severity, Converter={StaticResource SeverityBrush}}" FontSize="10" FontWeight="Bold" />
                                                                </Border>
                                                                <TextBlock Text="{Binding ModuleName}" Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Message}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,10,18,0" />
                                                            <StackPanel Margin="0,10,0,0">
                                                                <TextBlock Text="{x:Static p:Strings.Finding_Recommended}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,6" />
                                                                <ItemsControl ItemsSource="{Binding FixChoices}">
                                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Background="#0D1D2B" BorderBrush="{Binding Tier, Converter={StaticResource RiskTierBrush}}" BorderThickness="1" CornerRadius="8" Padding="8,5" Margin="0,0,7,7">
                                                                                <CheckBox IsChecked="{Binding IsSelected}" IsEnabled="{Binding IsAvailable}">
                                                                                    <StackPanel Orientation="Horizontal">
                                                                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextBrush}" FontSize="10.5" />
                                                                                        <TextBlock Text=" · " Foreground="{StaticResource MutedBrush}" FontSize="9.5" />
                                                                                        <TextBlock Text="{Binding TierLabel}" Foreground="{Binding Tier, Converter={StaticResource RiskTierBrush}}" FontSize="9.5" FontWeight="SemiBold" />
                                                                                    </StackPanel>
                                                                                </CheckBox>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Text="{Binding NoAutomaticFixLabel}" Foreground="{StaticResource MutedBrush}" FontSize="10.5" FontStyle="Italic" Visibility="{Binding HasNoAutomaticFix, Converter={StaticResource BoolToVisibility}}" />
                                                            </StackPanel>
                                                            <Expander Margin="0,10,0,0" Foreground="{StaticResource MutedBrush}">
                                                                <Expander.Header><TextBlock Text="{x:Static p:Strings.Finding_TechnicalDetail}" Foreground="{StaticResource MutedBrush}" FontSize="11" /></Expander.Header>
                                                                <Border Background="#08131F" CornerRadius="8" Padding="12" Margin="0,7,0,0"><TextBlock Text="{Binding TechnicalDetail}" FontFamily="Cascadia Mono, Consolas" FontSize="10.5" Foreground="#AFC5DB" TextWrapping="Wrap" /></Border>
                                                            </Expander>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                            <Border Background="#101A27" BorderBrush="{Binding RecommendedTier, Converter={StaticResource RiskTierBrush}}" BorderThickness="1" CornerRadius="8" Padding="9,5">
                                                                <TextBlock Text="{Binding StatusLabel}" FontSize="10" Foreground="{StaticResource TextBrush}" />
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </ScrollViewer>

                            <Grid Grid.Row="2" Margin="0,14,0,0" Visibility="{Binding Findings.Count, Converter={StaticResource CountToVisibility}}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <Border Background="#10263B" BorderBrush="#315476" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,8" Visibility="{Binding ExpertMode, Converter={StaticResource BoolToVisibility}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{x:Static p:Strings.Expert_TierSelector}" Foreground="{StaticResource BlueBrush}" FontSize="11" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding CurrentTierLabel}" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,3,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding SetRiskTierCommand}" CommandParameter="1" Content="{x:Static p:Strings.Tier_Safe}" Padding="11,7" Margin="0,0,5,0" />
                                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding SetRiskTierCommand}" CommandParameter="2" Content="{x:Static p:Strings.Tier_Moderate}" Padding="11,7" Margin="0,0,5,0" />
                                                <Button Style="{StaticResource DangerButton}" Command="{Binding SetRiskTierCommand}" CommandParameter="3" Content="{x:Static p:Strings.Tier_Aggressive}" Padding="11,7" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="#102418" BorderBrush="#2F6B4A" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,8" Visibility="{Binding ShowVerificationSummary, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding VerificationSummaryTitle}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding VerificationSummaryText}" Foreground="#C5DCCF" TextWrapping="Wrap" FontSize="11" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#271E18" BorderBrush="#6B4B29" BorderThickness="1" CornerRadius="12" Padding="14" Visibility="{Binding ShowEscalation, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel>
                                            <TextBlock Text="{x:Static p:Strings.Escalation_Title}" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding EscalationText}" Foreground="#DCC9B0" TextWrapping="Wrap" FontSize="11" Margin="0,4,0,0" />
                                            <CheckBox Content="{x:Static p:Strings.Force_Accept}" IsChecked="{Binding RiskAccepted}" Margin="0,10,0,0" Visibility="{Binding IsForceStage, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#151F2E" BorderBrush="#526B8B" BorderThickness="1" CornerRadius="12" Padding="14" Visibility="{Binding ShowHandoff, Converter={StaticResource BoolToVisibility}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <Border Width="40" Height="40" CornerRadius="11" Background="#1A3047" Margin="0,0,12,0">
                                                <app:SvgIcon Icon="integrity.svg" Width="22" Height="22" IsHitTestVisible="False" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                                <TextBlock Text="{Binding HandoffTitle}" Foreground="#D8E8FA" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding HandoffDescription}" Foreground="#AFC2D8" TextWrapping="Wrap" FontSize="10.5" Margin="0,4,0,0" />
                                                <TextBlock Text="{Binding HandoffNextSteps}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" FontSize="10" Margin="0,6,0,0" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Command="{Binding CreateSupportPackageCommand}" Content="{x:Static p:Strings.Action_CreateSupportPackage}" Padding="12,8" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" Content="{x:Static p:Strings.Action_Cancel}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Margin="0,0,8,0" />
                                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding RepairSelectedCommand}" Content="{Binding RepairButtonText}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" Visibility="{Binding ShowHandoff, Converter={StaticResource InverseBoolToVisibility}}" Padding="24,12" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- Live tests -->
                    <TabItem>
                        <ScrollViewer>
                            <Grid MaxWidth="1120" Margin="32,28,32,38">
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                    <TextBlock Text="{x:Static p:Strings.LiveTests_Title}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="28" FontWeight="Bold" />
                                    <TextBlock Text="{x:Static p:Strings.LiveTests_Description}" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" />
                                </StackPanel>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding LiveTests}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource AnimatedCardStyle}" Width="340" MinHeight="202" Margin="0,0,14,14" BorderBrush="{Binding ResultSeverity, Converter={StaticResource SeverityBrush}}">
                                                <Grid>
                                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                        <Border x:Name="TestIconShell" Width="50" Height="50" CornerRadius="15" Background="#153632" RenderTransformOrigin="0.5,0.5">
                                                            <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1" /></Border.RenderTransform>
                                                            <Grid>
                                                                <Ellipse x:Name="PulseRing" Width="44" Height="44" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.4" Opacity="0" RenderTransformOrigin="0.5,0.5">
                                                                    <Ellipse.RenderTransform><ScaleTransform ScaleX="0.7" ScaleY="0.7" /></Ellipse.RenderTransform>
                                                                </Ellipse>
                                                                <app:SvgIcon Icon="{Binding IconPath}" Width="27" Height="27" IsHitTestVisible="False" />
                                                            </Grid>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="14,1,0,0">
                                                            <TextBlock Text="{Binding ModuleName}" Foreground="{StaticResource PrimaryBrush}" FontSize="10" FontWeight="Bold" />
                                                            <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" Margin="0,5,0,0" TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <Grid Grid.Row="1" Margin="0,13,0,14">
                                                        <StackPanel x:Name="Waveform" Orientation="Horizontal" Height="28" HorizontalAlignment="Right" VerticalAlignment="Top" Visibility="{Binding IsAudioTest, Converter={StaticResource BoolToVisibility}}">
                                                            <Rectangle x:Name="Wave1" Width="4" Height="7" RadiusX="2" Fill="{StaticResource PrimaryBrush}" Margin="2" VerticalAlignment="Center" />
                                                            <Rectangle x:Name="Wave2" Width="4" Height="14" RadiusX="2" Fill="{StaticResource PrimaryBrush}" Margin="2" VerticalAlignment="Center" />
                                                            <Rectangle x:Name="Wave3" Width="4" Height="21" RadiusX="2" Fill="{StaticResource PrimaryBrush}" Margin="2" VerticalAlignment="Center" />
                                                            <Rectangle x:Name="Wave4" Width="4" Height="11" RadiusX="2" Fill="{StaticResource PrimaryBrush}" Margin="2" VerticalAlignment="Center" />
                                                            <Rectangle x:Name="Wave5" Width="4" Height="17" RadiusX="2" Fill="{StaticResource PrimaryBrush}" Margin="2" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <TextBlock x:Name="RunningLabel" Text="{x:Static p:Strings.LiveTest_Running}" Foreground="{StaticResource PrimaryBrush}" FontSize="10" FontWeight="SemiBold" Visibility="Collapsed" />
                                                        <TextBlock Text="{Binding LastResult}" Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,22,0,0" MaxHeight="34" />
                                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Margin="0,12,0,0" VerticalAlignment="Bottom" />
                                                    </Grid>
                                                    <Button x:Name="RunTestButton" Grid.Row="2" Style="{StaticResource SecondaryButton}" Command="{Binding RunCommand}" Content="{x:Static p:Strings.Action_RunTest}" />
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter TargetName="RunTestButton" Property="IsEnabled" Value="False" />
                                                    <Setter TargetName="RunningLabel" Property="Visibility" Value="Visible" />
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="LiveTestAnimation">
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetName="PulseRing" Storyboard.TargetProperty="Opacity" From="0.8" To="0" Duration="0:0:1.15" />
                                                                <DoubleAnimation Storyboard.TargetName="PulseRing" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.7" To="1.65" Duration="0:0:1.15" />
                                                                <DoubleAnimation Storyboard.TargetName="PulseRing" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.7" To="1.65" Duration="0:0:1.15" />
                                                                <DoubleAnimation Storyboard.TargetName="TestIconShell" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1" To="1.07" Duration="0:0:0.5" AutoReverse="True" />
                                                                <DoubleAnimation Storyboard.TargetName="TestIconShell" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1" To="1.07" Duration="0:0:0.5" AutoReverse="True" />
                                                                <DoubleAnimation Storyboard.TargetName="Wave1" Storyboard.TargetProperty="Height" From="6" To="22" Duration="0:0:0.34" AutoReverse="True" />
                                                                <DoubleAnimation Storyboard.TargetName="Wave2" Storyboard.TargetProperty="Height" From="14" To="5" Duration="0:0:0.46" AutoReverse="True" />
                                                                <DoubleAnimation Storyboard.TargetName="Wave3" Storyboard.TargetProperty="Height" From="8" To="26" Duration="0:0:0.39" AutoReverse="True" />
                                                                <DoubleAnimation Storyboard.TargetName="Wave4" Storyboard.TargetProperty="Height" From="18" To="6" Duration="0:0:0.42" AutoReverse="True" />
                                                                <DoubleAnimation Storyboard.TargetName="Wave5" Storyboard.TargetProperty="Height" From="7" To="20" Duration="0:0:0.36" AutoReverse="True" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions><StopStoryboard BeginStoryboardName="LiveTestAnimation" /></DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Grid.Row="2"
                                        Style="{StaticResource CardStyle}"
                                        Margin="0,8,0,0"
                                        Visibility="{Binding LiveMetricRows.Count, Converter={StaticResource CountToVisibility}}">
                                    <StackPanel>
                                        <TextBlock Text="{x:Static p:Strings.LiveMetrics_Title}" FontSize="16" FontWeight="SemiBold" />
                                        <Grid Margin="0,14,0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="1.7*" />
                                                <ColumnDefinition Width="2.8*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{x:Static p:Strings.LiveMetrics_Test}" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Bold" Margin="12,0" />
                                            <TextBlock Grid.Column="1" Text="{x:Static p:Strings.LiveMetrics_Result}" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Bold" Margin="12,0" />
                                            <TextBlock Grid.Column="2" Text="{x:Static p:Strings.LiveMetrics_Measurements}" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Bold" Margin="12,0" />
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding LiveMetricRows}">
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter"><Setter Property="HorizontalAlignment" Value="Stretch" /></Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#0B1929" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="9" Margin="0,0,0,7">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="1.2*" />
                                                                <ColumnDefinition Width="1.7*" />
                                                                <ColumnDefinition Width="2.8*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="3" Background="{Binding Severity, Converter={StaticResource SeverityBrush}}" CornerRadius="9,0,0,9" HorizontalAlignment="Left" />
                                                            <TextBlock Text="{Binding Test}" Margin="12,11" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Result}" Margin="12,11" Foreground="#C3D3E4" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="2" Text="{Binding Measurements}" Margin="12,11" Foreground="#AEC4DA" FontFamily="Cascadia Mono, Consolas" FontSize="10.5" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{x:Static p:Strings.LiveTests_Output}" FontWeight="SemiBold" />
                                        <ItemsControl ItemsSource="{Binding TestOutput}" Margin="0,10,0,0">
                                            <ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" FontFamily="Cascadia Mono, Consolas" Foreground="#AEC4DA" FontSize="11" Margin="0,2" TextWrapping="Wrap" /></DataTemplate></ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Recovery -->
                    <TabItem>
                        <Grid Margin="32,28,32,26">
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{x:Static p:Strings.Recovery_Title}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="28" FontWeight="Bold" />
                                    <TextBlock Text="{x:Static p:Strings.Recovery_Description}" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelCommand}"
                                        Content="{x:Static p:Strings.Action_Cancel}"
                                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                                        VerticalAlignment="Center"
                                        Padding="18,10" />
                            </Grid>
                            <ScrollViewer Grid.Row="1">
                                <Grid>
                                    <TextBlock Text="{x:Static p:Strings.Recovery_None}" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,80" Visibility="{Binding RecoverySessions.Count, Converter={StaticResource ZeroCountToVisibility}}" />
                                    <ItemsControl ItemsSource="{Binding RecoverySessions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,11">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                            <Border Width="44" Height="44" CornerRadius="13" Background="#173A37"><app:SvgIcon Icon="recovery.svg" Width="23" Height="23" IsHitTestVisible="False" /></Border>
                                                            <StackPanel Grid.Column="1" Margin="14,0">
                                                                <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,5,0,0" TextWrapping="Wrap" />
                                                            </StackPanel>
                                                            <WrapPanel Grid.Column="2" HorizontalAlignment="Right">
                                                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding OpenFolderCommand}" Content="{x:Static p:Strings.Action_OpenFolder}" Margin="0,0,8,0" />
                                                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding DismissCommand}" Content="{x:Static p:Strings.Action_DismissRecovery}" IsEnabled="{Binding IsDismissAvailable}" Margin="0,0,8,0" Visibility="{Binding IsDismissAvailable, Converter={StaticResource BoolToVisibility}}" />
                                                                <Button Style="{StaticResource DangerButton}" Command="{Binding UndoCommand}" Content="{x:Static p:Strings.Action_UndoSession}" IsEnabled="{Binding IsUndoAvailable}" />
                                                            </WrapPanel>
                                                        </Grid>
                                                        <ItemsControl ItemsSource="{Binding Actions}" Margin="58,14,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="0,10">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                                            <StackPanel Margin="0,0,16,0">
                                                                                <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                                                <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,3,0,0" TextWrapping="Wrap" />
                                                                            </StackPanel>
                                                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding DismissCommand}" Content="{x:Static p:Strings.Action_DismissRecovery}" IsEnabled="{Binding IsDismissAvailable}" Visibility="{Binding IsDismissAvailable, Converter={StaticResource BoolToVisibility}}" Padding="10,6" Margin="0,0,8,0" />
                                                                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding UndoCommand}" Content="{x:Static p:Strings.Action_UndoAction}" IsEnabled="{Binding IsUndoAvailable}" Padding="10,6" />
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- Settings -->
                    <TabItem>
                        <ScrollViewer>
                            <Grid MaxWidth="900" Margin="32,28,32,38" HorizontalAlignment="Left">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{x:Static p:Strings.Settings_Title}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="28" FontWeight="Bold" Margin="0,0,0,22" />
                                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="{x:Static p:Strings.Settings_DryRun}" FontSize="16" FontWeight="SemiBold" /><TextBlock Text="{x:Static p:Strings.Settings_DryRunDescription}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,30,0" /></StackPanel>
                                        <CheckBox Grid.Column="1" IsChecked="{Binding DryRun}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="{x:Static p:Strings.Settings_Expert}" FontSize="16" FontWeight="SemiBold" /><TextBlock Text="{x:Static p:Strings.Settings_ExpertDescription}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,30,0" /></StackPanel>
                                        <CheckBox Grid.Column="1" IsChecked="{Binding ExpertMode}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                    <StackPanel><TextBlock Text="{x:Static p:Strings.Settings_Offline}" FontSize="16" FontWeight="SemiBold" /><TextBlock Text="{x:Static p:Strings.Settings_OfflineDescription}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0" /></StackPanel>
                                </Border>
                                <Border Grid.Row="4" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,20,0">
                                            <TextBlock Text="{x:Static p:Strings.Settings_Language}" FontSize="16" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Static p:Strings.Settings_LanguageDescription}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,10" />
                                            <TextBlock Text="{Binding CurrentLanguageLabel}" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  Style="{StaticResource DarkComboBox}"
                                                  Width="270"
                                                  VerticalAlignment="Center"
                                                  ItemsSource="{Binding Languages}"
                                                  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                                  DisplayMemberPath="DisplayName"
                                                  IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                                    </Grid>
                                </Border>
                                <!-- Always-available manual Windows repair tools (Microsoft-oriented toolkit) -->
                                <Border Grid.Row="5" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="{x:Static p:Strings.Settings_ManualTools}" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Static p:Strings.Settings_ManualToolsDescription}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,10" />
                                        <Border Background="#271E18" BorderBrush="#6B4B29" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,14">
                                            <TextBlock Text="{x:Static p:Strings.Settings_ManualToolsRisk}" Foreground="#E8D2B4" FontSize="11.5" TextWrapping="Wrap" LineHeight="17" />
                                        </Border>
                                        <ItemsControl ItemsSource="{Binding ManualTools}">
                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="392" MinHeight="78" Background="#0B1825" BorderBrush="{Binding Tier, Converter={StaticResource RiskTierBrush}}" BorderThickness="1" CornerRadius="10" Padding="11" Margin="0,0,10,10">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                            <StackPanel Margin="0,0,12,0">
                                                                <TextBlock Text="{Binding ModuleName}" Foreground="{StaticResource MutedBrush}" FontSize="9.5" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding Title}" FontSize="11.5" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,3,0,0" />
                                                                <TextBlock Text="{Binding Detail}" Foreground="{StaticResource MutedBrush}" FontSize="9" TextWrapping="Wrap" Margin="0,4,0,0" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                                                <Border BorderBrush="{Binding Tier, Converter={StaticResource RiskTierBrush}}" BorderThickness="1" CornerRadius="7" Padding="7,4" HorizontalAlignment="Right">
                                                                    <TextBlock Text="{Binding TierLabel}" Foreground="{Binding Tier, Converter={StaticResource RiskTierBrush}}" FontSize="9" FontWeight="Bold" />
                                                                </Border>
                                                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding RunCommand}" Content="{x:Static p:Strings.Action_RunTool}" Padding="10,5" Margin="0,8,0,0" HorizontalAlignment="Right" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="6" Style="{StaticResource CardStyle}" Visibility="{Binding ExpertMode, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel>
                                        <TextBlock Text="{x:Static p:Strings.Settings_ExpertCatalog}" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Static p:Strings.Settings_ExpertCatalogDescription}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,14" />
                                        <ItemsControl ItemsSource="{Binding ExpertFixes}">
                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="392" MinHeight="74" Background="#0B1825" BorderBrush="{Binding Tier, Converter={StaticResource RiskTierBrush}}" BorderThickness="1" CornerRadius="10" Padding="11" Margin="0,0,10,10">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                            <StackPanel Margin="0,0,12,0">
                                                                <TextBlock Text="{Binding ModuleName}" Foreground="{StaticResource MutedBrush}" FontSize="9.5" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding Title}" FontSize="11.5" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,3,0,0" />
                                                                <TextBlock Text="{Binding Detail}" Foreground="{StaticResource MutedBrush}" FontSize="9" TextWrapping="Wrap" Margin="0,4,0,0" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                                                <Border BorderBrush="{Binding Tier, Converter={StaticResource RiskTierBrush}}" BorderThickness="1" CornerRadius="7" Padding="7,4" HorizontalAlignment="Right">
                                                                    <TextBlock Text="{Binding TierLabel}" Foreground="{Binding Tier, Converter={StaticResource RiskTierBrush}}" FontSize="9" FontWeight="Bold" />
                                                                </Border>
                                                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding RunCommand}" Content="{x:Static p:Strings.Action_RunExpertFix}" Padding="10,5" Margin="0,8,0,0" HorizontalAlignment="Right" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <!-- Console -->
                <Border Grid.Row="2" Background="#060D16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Visibility="{Binding ConsoleExpanded, Converter={StaticResource BoolToVisibility}}">
                    <Grid Height="185">
                        <Grid.RowDefinitions><RowDefinition Height="38" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <Grid Grid.Row="0" Background="#09131F">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center"><Ellipse Width="7" Height="7" Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0" /><TextBlock Text="{x:Static p:Strings.Console_Title}" FontWeight="SemiBold" FontSize="11" /><TextBlock Text="{x:Static p:Strings.Console_Hint}" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="12,0,0,0" /></StackPanel>
                            <Button Grid.Column="1" Command="{Binding ToggleConsoleCommand}" Background="Transparent" BorderThickness="0" Width="42"><app:SvgIcon Icon="chevron-down.svg" Width="15" Height="15" IsHitTestVisible="False" /></Button>
                        </Grid>
                        <ListBox x:Name="ConsoleList" Grid.Row="1" ItemsSource="{Binding ConsoleLines}" Background="Transparent" BorderThickness="0" Padding="12,6" FontFamily="Cascadia Mono, Consolas" ScrollViewer.HorizontalScrollBarVisibility="Auto" VirtualizingPanel.IsVirtualizing="True">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,1">
                                        <TextBlock Text="{Binding Time}" Foreground="#52677E" FontSize="10" Width="58" />
                                        <TextBlock Text="{Binding Level}" Foreground="{Binding Level, Converter={StaticResource ConsoleBrush}}" FontSize="10" FontWeight="Bold" Width="42" />
                                        <TextBlock Text="{Binding Text}" Foreground="{Binding Level, Converter={StaticResource ConsoleBrush}}" FontSize="10.5" TextWrapping="NoWrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Full-screen module detail panel (home area expand) -->
                <Border Grid.Row="0" Grid.RowSpan="4"
                        Background="#F207101D"
                        Visibility="{Binding HasSelectedModule, Converter={StaticResource BoolToVisibility}}"
                        Panel.ZIndex="30">
                    <Border Margin="18"
                            Background="#0C1828"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0" Background="#102035" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" CornerRadius="18,18,0,0" Padding="28,22">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="64" Height="64" CornerRadius="18" Background="#173A37" Margin="0,0,18,0">
                                        <app:SvgIcon Icon="{Binding SelectedModuleIcon}" Width="34" Height="34" IsHitTestVisible="False" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{x:Static p:Strings.ModulePanel_Details}" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="Bold" />
                                        <TextBlock Text="{Binding SelectedModuleName}" FontSize="26" FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedModuleDescription}" Foreground="#AEC4DA" FontSize="13.5" Margin="0,8,0,0" TextWrapping="Wrap" LineHeight="21" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding CloseModulePanelCommand}"
                                            Content="{x:Static p:Strings.Action_ClosePanel}"
                                            Padding="16,10"
                                            VerticalAlignment="Top" />
                                </Grid>
                            </Border>

                            <!-- Body: symptoms + actions -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,22,28,12">
                                <StackPanel>
                                    <TextBlock Text="{x:Static p:Strings.ModulePanel_Symptoms}" Foreground="{StaticResource MutedBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12" />
                                    <TextBlock Text="{x:Static p:Strings.ModulePanel_NoSymptoms}"
                                               Foreground="#6F849B"
                                               FontSize="13"
                                               Margin="0,0,0,16"
                                               Visibility="{Binding Symptoms.Count, Converter={StaticResource ZeroCountToVisibility}}" />
                                    <ItemsControl ItemsSource="{Binding Symptoms}" Margin="0,0,0,8">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource SecondaryButton}"
                                                        Command="{Binding RunCommand}"
                                                        Content="{Binding Title}"
                                                        Margin="0,0,10,10"
                                                        Padding="16,12"
                                                        MinWidth="180"
                                                        HorizontalContentAlignment="Left" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border Background="#0B1825" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="14" Padding="18" Margin="0,10,0,0">
                                        <TextBlock Text="{x:Static p:Strings.ModulePanel_Hint}"
                                                   Foreground="#9DB0C8"
                                                   FontSize="12.5"
                                                   TextWrapping="Wrap"
                                                   LineHeight="19" />
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Footer actions -->
                            <Border Grid.Row="2" Background="#0A1522" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" CornerRadius="0,0,18,18" Padding="28,16">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource SecondaryButton}"
                                            Command="{Binding CloseModulePanelCommand}"
                                            Content="{x:Static p:Strings.Action_ClosePanel}"
                                            Padding="18,11"
                                            Margin="0,0,10,0" />
                                    <Button Style="{StaticResource PrimaryButton}"
                                            Command="{Binding ScanSelectedModuleCommand}"
                                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                            Padding="22,11">
                                        <StackPanel Orientation="Horizontal">
                                            <app:SvgIcon Icon="search.svg" Width="16" Height="16" Margin="0,0,9,0" IsHitTestVisible="False" />
                                            <TextBlock Text="{x:Static p:Strings.Action_ScanModule}" Foreground="#07110F" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Border>

                <!-- Full-screen operation overlay / scan summary -->
                <Border Grid.Row="0" Grid.RowSpan="4"
                        Background="#E607101D"
                        Visibility="{Binding ShowOperationOverlay, Converter={StaticResource BoolToVisibility}}"
                        Panel.ZIndex="40">
                    <!-- Stretch + constrained height so the feed ScrollViewer can scroll instead of growing the dialog -->
                    <Border MaxWidth="900" MinHeight="420" Margin="24"
                            HorizontalAlignment="Center" VerticalAlignment="Stretch"
                            Background="#102035" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="20" Padding="28">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="140" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <Border Width="56" Height="56" CornerRadius="16" Background="#173A37" Margin="0,0,16,0">
                                    <app:SvgIcon Icon="{Binding OperationIcon}" Width="30" Height="30" IsHitTestVisible="False" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding OperationPhase}" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="Bold" />
                                    <TextBlock Text="{Binding OperationTitle}" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding OperationDetail}" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,6,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Live counters -->
                            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,14">
                                <Border Background="#0B1825" CornerRadius="12" Padding="12,10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="{x:Static p:Strings.Operation_StatPassed}" Foreground="{StaticResource MutedBrush}" FontSize="10" />
                                        <TextBlock Text="{Binding OperationPassedCount}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#0B1825" CornerRadius="12" Padding="12,10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="{x:Static p:Strings.Operation_StatFindings}" Foreground="{StaticResource MutedBrush}" FontSize="10" />
                                        <TextBlock Text="{Binding OperationFindingCount}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#0B1825" CornerRadius="12" Padding="12,10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="{x:Static p:Strings.Operation_StatCommon}" Foreground="{StaticResource MutedBrush}" FontSize="10" />
                                        <TextBlock Text="{Binding OperationCommonFindingCount}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BlueBrush}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#0B1825" CornerRadius="12" Padding="12,10">
                                    <StackPanel>
                                        <TextBlock Text="{x:Static p:Strings.Operation_StatActionable}" Foreground="{StaticResource MutedBrush}" FontSize="10" />
                                        <TextBlock Text="{Binding OperationActionableFindingCount}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource DangerBrush}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <StackPanel Grid.Row="2" Margin="0,0,0,12" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ProgressStatusText}"
                                               Foreground="#AEC4DA"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ProgressPercentText}"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <ProgressBar Style="{StaticResource OperationProgressBar}"
                                             Value="{Binding ProgressValue}"
                                             Maximum="100"
                                             Height="14" />
                                <Grid Margin="0,8,0,0">
                                    <TextBlock Text="{Binding ActiveOperation}"
                                               Foreground="#7F96AD"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding ProgressEtaText}"
                                               Foreground="{StaticResource WarningBrush}"
                                               FontSize="11.5"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                            <TextBlock Grid.Row="3" Height="0" Visibility="Collapsed" />

                            <Border Grid.Row="4" Background="#0B1825" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="12" Padding="12" MinHeight="140">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding OperationSummaryAdvice}" Foreground="#AEC4DA" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Visibility="{Binding ShowOperationSummary, Converter={StaticResource BoolToVisibility}}" />
                                    <ScrollViewer x:Name="OperationFeedScroll"
                                                  Grid.Row="1"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  CanContentScroll="False">
                                        <ItemsControl x:Name="OperationFeedList" ItemsSource="{Binding OperationFeed}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Time}" Foreground="#52677E" FontSize="10.5" Width="58" VerticalAlignment="Center" />
                                                        <Border Grid.Column="1" Width="28" Height="28" CornerRadius="8" Background="#122033" Margin="0,0,10,0">
                                                            <app:SvgIcon Icon="{Binding Icon}" Width="16" Height="16" IsHitTestVisible="False" />
                                                        </Border>
                                                        <TextBlock Grid.Column="2" Text="{Binding Text}" Foreground="#D7E5F4" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <!-- Busy actions -->
                            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                                <Button Style="{StaticResource SecondaryButton}"
                                        Command="{Binding SkipRestorePointCommand}"
                                        Content="{x:Static p:Strings.Action_SkipRestorePoint}"
                                        Padding="18,11"
                                        Margin="0,0,8,0"
                                        Visibility="{Binding CanSkipRestorePoint, Converter={StaticResource BoolToVisibility}}" />
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" Content="{x:Static p:Strings.Action_Cancel}" Padding="22,11" />
                            </StackPanel>

                            <!-- Summary actions -->
                            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0" Visibility="{Binding ShowOperationSummary, Converter={StaticResource BoolToVisibility}}">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CloseOperationSummaryCommand}" Content="{x:Static p:Strings.Action_ClosePanel}" Padding="16,10" Margin="0,0,8,0" />
                                <Button Style="{StaticResource SecondaryButton}"
                                        Command="{Binding OpenGuidedRepairFromSummaryCommand}"
                                        Content="{x:Static p:Strings.Action_StillHaveProblem}"
                                        Padding="16,10"
                                        Margin="0,0,8,0"
                                        Visibility="{Binding OperationFindingCount, Converter={StaticResource ZeroCountToVisibility}}" />
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding ViewFindingsFromSummaryCommand}" Content="{x:Static p:Strings.Action_ViewFindings}" Padding="16,10" Margin="0,0,8,0" />
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding ForceRepairAllFromSummaryCommand}" Content="{x:Static p:Strings.Action_ForceRepairAll}" Padding="16,10" Margin="0,0,8,0" />
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ForceRepairFromSummaryCommand}" Padding="18,10">
                                    <StackPanel Orientation="Horizontal">
                                        <app:SvgIcon Icon="wrench-on-primary.svg" Width="16" Height="16" Margin="0,0,8,0" IsHitTestVisible="False" />
                                        <TextBlock Text="{x:Static p:Strings.Action_ForceRepairReal}" Foreground="#07110F" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Border>

                <!-- Guided symptom repair confirmation (risk + side effects) -->
                <Border Grid.Row="0" Grid.RowSpan="4"
                        Background="#F207101D"
                        Visibility="{Binding ShowGuidedRepairConfirm, Converter={StaticResource BoolToVisibility}}"
                        Panel.ZIndex="35">
                    <Border MaxWidth="760" Margin="28"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#122033" BorderBrush="#6B4B29" BorderThickness="1"
                            CornerRadius="18" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#271E18" BorderBrush="#6B4B29" BorderThickness="0,0,0,1" CornerRadius="18,18,0,0" Padding="24,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="56" Height="56" CornerRadius="16" Background="#3A2A1C" Margin="0,0,16,0">
                                        <app:SvgIcon Icon="{Binding GuidedRepairIcon}" Width="30" Height="30" IsHitTestVisible="False" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Static p:Strings.GuidedRepair_ConfirmTitle}" Foreground="{StaticResource WarningBrush}" FontSize="12" FontWeight="Bold" />
                                        <TextBlock Text="{Binding GuidedRepairTitle}" FontSize="22" FontWeight="SemiBold" Margin="0,5,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding GuidedRepairModule}" Foreground="#DCC9B0" FontSize="12.5" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="420" Padding="24,18">
                                <StackPanel>
                                    <Border Background="#321C24" BorderBrush="#7A3A4A" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,14">
                                        <TextBlock Text="{Binding GuidedRepairWarning}" Foreground="#FFD6DE" FontSize="12.5" TextWrapping="Wrap" LineHeight="19" />
                                    </Border>

                                    <TextBlock Text="{x:Static p:Strings.GuidedRepair_SideEffectsTitle}" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" />
                                    <Border Background="#271E18" BorderBrush="#6B4B29" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,16">
                                        <TextBlock Text="{Binding GuidedRepairSideEffects}" Foreground="#E8D2B4" FontSize="12.5" TextWrapping="Wrap" LineHeight="20" />
                                    </Border>

                                    <TextBlock Text="{x:Static p:Strings.GuidedRepair_FixesTitle}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" />
                                    <Border Background="#0B1825" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,16">
                                        <ItemsControl ItemsSource="{Binding GuidedRepairFixList}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                        <TextBlock Text="•" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" />
                                                        <TextBlock Text="{Binding}" Foreground="#D7E5F4" FontSize="12.5" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <CheckBox IsChecked="{Binding GuidedRepairRiskAccepted}"
                                              Foreground="#F2F7FF"
                                              FontSize="12.5"
                                              Margin="2,0,0,0">
                                        <TextBlock Text="{x:Static p:Strings.GuidedRepair_AcceptRisk}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#F2F7FF"
                                                   FontSize="12.5"
                                                   MaxWidth="640" />
                                    </CheckBox>
                                </StackPanel>
                            </ScrollViewer>

                            <Border Grid.Row="2" Background="#0A1522" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" CornerRadius="0,0,18,18" Padding="24,16">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource SecondaryButton}"
                                            Command="{Binding CancelGuidedRepairCommand}"
                                            Content="{x:Static p:Strings.Action_Cancel}"
                                            Padding="18,11"
                                            Margin="0,0,10,0" />
                                    <Button Style="{StaticResource DangerButton}"
                                            Command="{Binding ConfirmGuidedRepairCommand}"
                                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                            Padding="18,11">
                                        <StackPanel Orientation="Horizontal">
                                            <app:SvgIcon Icon="wrench.svg" Width="16" Height="16" Margin="0,0,9,0" IsHitTestVisible="False" />
                                            <TextBlock Text="{x:Static p:Strings.Action_ApplySymptomRepairs}" Foreground="#FFD6DE" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Border>

                <!-- Live toast notifications -->
                <ItemsControl Grid.Row="0" Grid.RowSpan="4"
                              ItemsSource="{Binding Toasts}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,22,54"
                              Panel.ZIndex="50"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border MinWidth="280" MaxWidth="380" Margin="0,0,0,10" Padding="14"
                                    Background="#12253A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="10" Background="#173A37" Margin="0,0,12,0">
                                        <app:SvgIcon Icon="{Binding Icon}" Width="18" Height="18" IsHitTestVisible="False" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12.5" />
                                        <TextBlock Text="{Binding Message}" Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Status bar -->
                <Border Grid.Row="3" Background="#0A1522" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <Grid MinHeight="38">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="250" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource BlueBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding StatusText}" Foreground="#B3C5D8" FontSize="11" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Grid Grid.Column="1" VerticalAlignment="Center" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ProgressBar Style="{StaticResource OperationProgressBar}" Value="{Binding ProgressValue}" Maximum="100" Height="8" />
                            <Grid Grid.Row="1" Margin="0,3,0,0">
                                <TextBlock Text="{Binding ProgressPercentText}" Foreground="{StaticResource PrimaryBrush}" FontSize="10" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ProgressEtaText}" Foreground="#9DB0C8" FontSize="10" HorizontalAlignment="Right" />
                            </Grid>
                        </Grid>
                        <Button Grid.Column="2" Command="{Binding ToggleConsoleCommand}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource MutedBrush}" Padding="14,5" Content="{x:Static p:Strings.Console_Title}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
